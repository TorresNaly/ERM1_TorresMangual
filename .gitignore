# History files
.Rhistory
.Rapp.history

# Imaging files
.dv

# Session data and workspaces
.RData
.RDataTmp
*.RData
*.RDataTmp

# User-specific RStudio configuration files
.Rproj.user/

# R environment variables (contains secrets/tokens)
.Renviron

